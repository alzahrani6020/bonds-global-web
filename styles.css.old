/* ═══════════════════════════════════════
   بوندز — نظام تصميم فاخر مخصص
   Bonds Global — Custom Luxury Design System
   ═══════════════════════════════════════ */

/* ─── CSS Variables ─── */
:root {
  /* Core Palette: Deep Navy + Warm Gold */
  --navy-950: #060d18;
  --navy-900: #0a1628;
  --navy-800: #12233d;
  --navy-700: #1a365d;
  --navy-600: #234a7a;
  --navy-500: #2c5e99;

  --gold-500: #c5a028;
  --gold-400: #d4b44a;
  --gold-300: #e3c86e;
  --gold-600: #9a7b2d;
  --gold-700: #745a1f;
  --gold-50:  #fbf7ed;
  --gold-100: #f5ecd0;

  --cream-50:  #faf8f5;
  --cream-100: #f5f0e8;
  --cream-200: #ebe4d8;
  --cream-300: #ddd3c3;

  --text-primary:   #0f172a;
  --text-secondary: #475569;
  --text-muted:     #64748b;
  --text-inverse:   #f8fafc;

  --white: #ffffff;
  --black: #000000;

  /* Surfaces */
  --surface:        var(--white);
  --surface-raised: var(--cream-50);
  --surface-dark:   var(--navy-900);

  /* Borders */
  --border-light:  rgba(18, 35, 61, 0.08);
  --border-medium: rgba(18, 35, 61, 0.14);
  --border-gold:   rgba(197, 160, 40, 0.35);

  /* Spacing Scale */
  --space-1: 0.25rem;
  --space-2: 0.5rem;
  --space-3: 0.75rem;
  --space-4: 1rem;
  --space-5: 1.25rem;
  --space-6: 1.5rem;
  --space-8: 2rem;
  --space-10: 2.5rem;
  --space-12: 3rem;
  --space-16: 4rem;
  --space-20: 5rem;
  --space-24: 6rem;
  --space-32: 8rem;

  /* Typography */
  --font: "Cairo", system-ui, -apple-system, sans-serif;
  --font-display: "Cairo", system-ui, sans-serif;

  --text-xs:   clamp(0.75rem, 0.8vw, 0.8125rem);
  --text-sm:   clamp(0.8125rem, 0.85vw, 0.9375rem);
  --text-base: clamp(0.9375rem, 1vw, 1.0625rem);
  --text-lg:   clamp(1.0625rem, 1.15vw, 1.1875rem);
  --text-xl:   clamp(1.25rem, 1.5vw, 1.5rem);
  --text-2xl:  clamp(1.5rem, 2vw, 2rem);
  --text-3xl:  clamp(2rem, 2.8vw, 2.75rem);
  --text-4xl:  clamp(2.5rem, 3.8vw, 3.5rem);
  --text-5xl:  clamp(3rem, 5vw, 4.5rem);
  --text-6xl:  clamp(3.5rem, 6vw, 5.5rem);

  /* Layout */
  --max-width: 1200px;
  --radius-sm: 8px;
  --radius:    14px;
  --radius-lg: 20px;
  --radius-xl: 28px;
  --radius-full: 9999px;

  /* Shadows */
  --shadow-sm:   0 1px 2px rgba(6, 13, 24, 0.04);
  --shadow:      0 4px 12px rgba(6, 13, 24, 0.06);
  --shadow-md:   0 8px 24px rgba(6, 13, 24, 0.08);
  --shadow-lg:   0 16px 48px rgba(6, 13, 24, 0.10);
  --shadow-xl:   0 24px 72px rgba(6, 13, 24, 0.14);
  --shadow-gold: 0 8px 32px rgba(197, 160, 40, 0.22);
  --shadow-gold-lg: 0 16px 48px rgba(197, 160, 40, 0.28);

  /* Transitions */
  --ease-out-expo: cubic-bezier(0.16, 1, 0.3, 1);
  --ease-out-back: cubic-bezier(0.34, 1.56, 0.64, 1);
  --transition-fast: 150ms var(--ease-out-expo);
  --transition:      350ms var(--ease-out-expo);
  --transition-slow: 600ms var(--ease-out-expo);
}

/* ─── Dark Mode ─── */
[data-theme="dark"] {
  --text-primary:   #f1f5f9;
  --text-secondary: #cbd5e1;
  --text-muted:     #94a3b8;
  --text-inverse:   #0f172a;

  --surface:        #0f172a;
  --surface-raised: #1e293b;
  --surface-dark:   #060d18;

  --cream-50:  #0f172a;
  --cream-100: #1e293b;
  --cream-200: #334155;
  --cream-300: #475569;

  --border-light:  rgba(255, 255, 255, 0.06);
  --border-medium: rgba(255, 255, 255, 0.10);
  --border-gold:   rgba(212, 180, 74, 0.25);

  --shadow-sm:   0 1px 2px rgba(0, 0, 0, 0.25);
  --shadow:      0 4px 12px rgba(0, 0, 0, 0.35);
  --shadow-md:   0 8px 24px rgba(0, 0, 0, 0.45);
  --shadow-lg:   0 16px 48px rgba(0, 0, 0, 0.55);
  --shadow-xl:   0 24px 72px rgba(0, 0, 0, 0.65);
  --shadow-gold: 0 8px 32px rgba(197, 160, 40, 0.15);
}

/* ─── Reset ─── */
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
html { scroll-behavior: smooth; }
body {
  font-family: var(--font);
  font-size: var(--text-base);
  color: var(--text-primary);
  background: var(--cream-50);
  line-height: 1.75;
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
  overflow-x: hidden;
}
img, svg { max-width: 100%; height: auto; display: block; }
a { color: inherit; text-decoration: none; transition: color var(--transition-fast); }
ul { list-style: none; }

/* ─── Utilities ─── */
.container {
  width: min(100% - var(--space-8), var(--max-width));
  margin-inline: auto;
}
.text-gradient {
  background: linear-gradient(135deg, var(--gold-400), var(--gold-300), var(--gold-500));
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}
.bg-gradient-gold {
  background: linear-gradient(135deg, var(--gold-400), var(--gold-500));
}
.glass {
  background: rgba(255, 255, 255, 0.72);
  backdrop-filter: blur(20px) saturate(1.6);
  -webkit-backdrop-filter: blur(20px) saturate(1.6);
  border: 1px solid var(--border-light);
}
[data-theme="dark"] .glass {
  background: rgba(15, 23, 42, 0.72);
  border-color: var(--border-light);
}

/* ─── Top Bar ─── */
.topbar {
  background: var(--navy-950);
  color: var(--gold-100);
  font-size: var(--text-xs);
  padding: var(--space-2) 0;
  border-bottom: 1px solid var(--border-gold);
}
.topbar__inner {
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.topbar a { color: var(--gold-300); font-weight: 700; }
.topbar a:hover { color: var(--white); }

/* ─── Header ─── */
.main-header {
  position: sticky;
  top: 0;
  z-index: 100;
  background: rgba(250, 248, 245, 0.88);
  backdrop-filter: blur(16px) saturate(1.4);
  -webkit-backdrop-filter: blur(16px) saturate(1.4);
  border-bottom: 1px solid var(--border-light);
  transition: box-shadow var(--transition), background var(--transition);
}
.main-header.scrolled {
  box-shadow: var(--shadow-md);
  background: rgba(250, 248, 245, 0.96);
}
[data-theme="dark"] .main-header {
  background: rgba(15, 23, 42, 0.88);
}
[data-theme="dark"] .main-header.scrolled {
  background: rgba(15, 23, 42, 0.96);
}
.main-header__inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: var(--space-3) 0;
  gap: var(--space-4);
}

/* Logo */
.logo-slot {
  display: flex;
  align-items: center;
  gap: var(--space-3);
}
.site-logo {
  height: 44px;
  width: auto;
  object-fit: contain;
}
.logo-text {
  font-family: var(--font-display);
  font-size: var(--text-xl);
  font-weight: 900;
  color: var(--navy-950);
  letter-spacing: -0.02em;
}
[data-theme="dark"] .logo-text { color: var(--white); }

/* Navigation */
.main-nav ul {
  display: flex;
  gap: var(--space-8);
  align-items: center;
}
.main-nav a {
  position: relative;
  color: var(--text-secondary);
  font-weight: 600;
  font-size: var(--text-sm);
  padding: var(--space-2) 0;
}
.main-nav a::after {
  content: "";
  position: absolute;
  bottom: -2px;
  right: 0;
  width: 0;
  height: 2px;
  background: linear-gradient(90deg, var(--gold-400), var(--gold-500));
  border-radius: 2px;
  transition: width var(--transition);
}
.main-nav a:hover { color: var(--navy-700); }
.main-nav a:hover::after,
.main-nav a.active::after { width: 100%; }
.main-nav a.active { color: var(--navy-800); font-weight: 700; }
[data-theme="dark"] .main-nav a { color: var(--text-muted); }
[data-theme="dark"] .main-nav a:hover { color: var(--white); }
[data-theme="dark"] .main-nav a.active { color: var(--gold-300); }

/* Dropdown Menu */
.dropdown {
  position: relative;
}
.dropdown-toggle {
  display: inline-flex;
  align-items: center;
  gap: var(--space-1);
  cursor: pointer;
}
.dropdown-toggle svg {
  width: 14px;
  height: 14px;
  transition: transform var(--transition);
}
.dropdown:hover .dropdown-toggle svg,
.dropdown.is-open .dropdown-toggle svg {
  transform: rotate(180deg);
}
.dropdown-menu {
  position: absolute;
  top: calc(100% + var(--space-2));
  right: 0;
  min-width: 220px;
  background: var(--surface);
  border: 1px solid var(--border-light);
  border-radius: var(--radius);
  box-shadow: var(--shadow-lg);
  padding: var(--space-2);
  opacity: 0;
  visibility: hidden;
  transform: translateY(-6px);
  transition: opacity var(--transition), transform var(--transition), visibility var(--transition);
  z-index: 200;
}
.dropdown:hover .dropdown-menu,
.dropdown.is-open .dropdown-menu {
  opacity: 1;
  visibility: visible;
  transform: translateY(0);
}
.dropdown-menu a {
  display: block;
  padding: var(--space-3) var(--space-4);
  border-radius: var(--radius-sm);
  font-size: var(--text-sm);
  font-weight: 500;
  color: var(--text-secondary);
  transition: background var(--transition), color var(--transition);
  white-space: nowrap;
}
.dropdown-menu a:hover {
  background: var(--cream-100);
  color: var(--navy-800);
}
.dropdown-menu a::after { display: none; }
[data-theme="dark"] .dropdown-menu {
  background: var(--navy-800);
  border-color: rgba(255,255,255,0.08);
}
[data-theme="dark"] .dropdown-menu a:hover {
  background: rgba(255,255,255,0.06);
  color: var(--white);
}

/* Header Actions */
.header-actions {
  display: flex;
  align-items: center;
  gap: var(--space-3);
}
.theme-toggle {
  width: 40px; height: 40px;
  display: flex; align-items: center; justify-content: center;
  background: none;
  border: 1px solid var(--border-light);
  border-radius: var(--radius);
  cursor: pointer;
  font-size: 1.1rem;
  transition: var(--transition-fast);
}
.theme-toggle:hover {
  background: var(--cream-100);
  border-color: var(--border-medium);
  transform: rotate(15deg);
}
[data-theme="dark"] .theme-toggle { border-color: var(--border-medium); }
[data-theme="dark"] .theme-toggle:hover { background: var(--surface-raised); }

/* Mobile Toggle */
.nav-toggle {
  display: none;
  background: none; border: none; cursor: pointer;
  padding: var(--space-2);
  flex-direction: column;
  gap: 5px;
}
.nav-toggle span {
  display: block;
  width: 24px; height: 2px;
  background: var(--text-primary);
  border-radius: 2px;
  transition: var(--transition-fast);
}
.nav-toggle.is-open span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
.nav-toggle.is-open span:nth-child(2) { opacity: 0; }
.nav-toggle.is-open span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

/* ─── Buttons ─── */
.btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: var(--space-2);
  padding: var(--space-3) var(--space-6);
  border-radius: var(--radius);
  font-weight: 700;
  font-size: var(--text-sm);
  cursor: pointer;
  border: none;
  transition: transform var(--transition-fast), box-shadow var(--transition-fast), background var(--transition-fast);
  font-family: inherit;
  line-height: 1.5;
  white-space: nowrap;
}
.btn:hover { transform: translateY(-2px); }
.btn:active { transform: translateY(0); }

.btn-primary {
  background: linear-gradient(135deg, var(--gold-400), var(--gold-500));
  color: var(--navy-950);
  box-shadow: var(--shadow-gold);
}
.btn-primary:hover {
  background: linear-gradient(135deg, var(--gold-300), var(--gold-400));
  box-shadow: var(--shadow-gold-lg);
}

.btn-secondary {
  background: var(--navy-800);
  color: var(--white);
  box-shadow: var(--shadow);
}
.btn-secondary:hover { background: var(--navy-700); box-shadow: var(--shadow-md); }

.btn-outline {
  background: transparent;
  color: var(--navy-800);
  border: 2px solid var(--navy-700);
}
.btn-outline:hover {
  background: var(--navy-800);
  color: var(--white);
}
[data-theme="dark"] .btn-outline {
  color: var(--white);
  border-color: var(--border-medium);
}
[data-theme="dark"] .btn-outline:hover {
  background: var(--surface-raised);
  border-color: var(--gold-400);
}

.btn-ghost {
  background: rgba(255,255,255,0.08);
  color: var(--white);
  border: 1px solid rgba(255,255,255,0.16);
}
.btn-ghost:hover { background: rgba(255,255,255,0.16); }

.btn-lg {
  padding: var(--space-4) var(--space-8);
  font-size: var(--text-base);
  border-radius: var(--radius-lg);
}

/* ─── Hero ─── */
.hero {
  position: relative;
  min-height: 92vh;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: var(--space-24) 0 var(--space-16);
  overflow: hidden;
  background:
    radial-gradient(ellipse 70% 50% at 20% 40%, rgba(197,160,40,0.10), transparent 60%),
    radial-gradient(ellipse 50% 40% at 80% 20%, rgba(26,54,93,0.08), transparent 50%),
    linear-gradient(180deg, var(--cream-50) 0%, var(--cream-100) 100%);
}
.hero::before {
  content: "";
  position: absolute;
  inset: 0;
  background-image: url("data:image/svg+xml,%3Csvg width='80' height='80' viewBox='0 0 80 80' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23c5a028' fill-opacity='0.025'%3E%3Cpath d='M50 48V40h-4v8h-8v4h8v8h4v-8h8v-4h-8zm0-40V0h-4v8h-8v4h8v8h4V12h8V8h-8zM10 48V40H6v8H0v4h6v8h4v-8h8v-4h-8zm0-40V0H6v8H0v4h6v8h4V12h8V8h-8z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E");
  opacity: 0.6;
  pointer-events: none;
}
[data-theme="dark"] .hero {
  background:
    radial-gradient(ellipse 70% 50% at 20% 40%, rgba(197,160,40,0.06), transparent 60%),
    radial-gradient(ellipse 50% 40% at 80% 20%, rgba(26,54,93,0.12), transparent 50%),
    linear-gradient(180deg, var(--surface-dark) 0%, var(--surface) 100%);
}

.hero__content {
  position: relative;
  z-index: 2;
  max-width: 800px;
  text-align: center;
  margin-inline: auto;
}

.hero__eyebrow {
  display: inline-flex;
  align-items: center;
  gap: var(--space-2);
  background: linear-gradient(135deg, rgba(197,160,40,0.12), rgba(197,160,40,0.06));
  color: var(--gold-600);
  padding: var(--space-2) var(--space-5);
  border-radius: var(--radius-full);
  font-size: var(--text-xs);
  font-weight: 800;
  margin-bottom: var(--space-6);
  border: 1px solid var(--border-gold);
  letter-spacing: 0.02em;
}
[data-theme="dark"] .hero__eyebrow {
  color: var(--gold-300);
  background: linear-gradient(135deg, rgba(197,160,40,0.15), rgba(197,160,40,0.05));
}

.hero__title {
  font-family: var(--font-display);
  font-size: var(--text-6xl);
  font-weight: 900;
  line-height: 1.1;
  color: var(--navy-950);
  margin-bottom: var(--space-6);
  letter-spacing: -0.03em;
}
[data-theme="dark"] .hero__title { color: var(--white); }

.hero__desc {
  font-size: var(--text-lg);
  color: var(--text-secondary);
  margin-bottom: var(--space-10);
  max-width: 600px;
  margin-inline: auto;
  line-height: 1.8;
}

.hero__actions {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-4);
  justify-content: center;
}

/* Hero Decorative Elements */
.hero__orb {
  position: absolute;
  border-radius: 50%;
  filter: blur(80px);
  pointer-events: none;
  opacity: 0.35;
}
.hero__orb--1 {
  width: 500px; height: 500px;
  background: radial-gradient(circle, rgba(197,160,40,0.25), transparent 70%);
  top: -10%; right: -10%;
  animation: orbFloat 12s ease-in-out infinite;
}
.hero__orb--2 {
  width: 400px; height: 400px;
  background: radial-gradient(circle, rgba(26,54,93,0.15), transparent 70%);
  bottom: -5%; left: -5%;
  animation: orbFloat 14s ease-in-out infinite reverse;
}

@keyframes orbFloat {
  0%, 100% { transform: translate(0, 0) scale(1); }
  33% { transform: translate(-20px, 15px) scale(1.05); }
  66% { transform: translate(15px, -10px) scale(0.95); }
}

/* ─── Stats Bar ─── */
.stats-bar {
  background: linear-gradient(135deg, var(--navy-950), var(--navy-800));
  color: var(--white);
  padding: var(--space-12) 0;
  position: relative;
  overflow: hidden;
}
.stats-bar::before {
  content: "";
  position: absolute;
  inset: 0;
  background: radial-gradient(circle at 30% 50%, rgba(197,160,40,0.10), transparent 50%);
}
.stats-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: var(--space-8);
  position: relative;
  z-index: 1;
}
.stat-item {
  text-align: center;
  position: relative;
}
.stat-item:not(:last-child)::after {
  content: "";
  position: absolute;
  left: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 1px;
  height: 60%;
  background: linear-gradient(180deg, transparent, rgba(255,255,255,0.15), transparent);
}
[dir="rtl"] .stat-item:not(:last-child)::after {
  left: auto;
  right: 0;
}
.stat-item__num {
  display: block;
  font-family: var(--font-display);
  font-size: var(--text-4xl);
  font-weight: 900;
  color: var(--gold-400);
  line-height: 1;
  margin-bottom: var(--space-2);
}
.stat-item__label {
  font-size: var(--text-sm);
  color: var(--cream-300);
  opacity: 0.8;
}

/* ─── Trust Bar ─── */
.trust-bar {
  background: var(--cream-100);
  border-block: 1px solid var(--border-light);
  padding: var(--space-10) 0;
  overflow: hidden;
}
[data-theme="dark"] .trust-bar {
  background: var(--surface-raised);
}
.trust-bar__title {
  text-align: center;
  font-size: var(--text-xs);
  color: var(--text-muted);
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.12em;
  margin-bottom: var(--space-6);
}
.trust-logos {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: var(--space-12);
  flex-wrap: wrap;
  opacity: 0.45;
}
.trust-logos span {
  font-weight: 800;
  font-size: var(--text-lg);
  color: var(--text-muted);
  white-space: nowrap;
  letter-spacing: -0.01em;
}

/* ─── Section Base ─── */
.section {
  padding: var(--space-24) 0;
}
.section-header {
  text-align: center;
  max-width: 640px;
  margin-inline: auto;
  margin-bottom: var(--space-16);
}
.section__eyebrow {
  display: inline-block;
  color: var(--gold-600);
  font-size: var(--text-xs);
  font-weight: 800;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  margin-bottom: var(--space-3);
}
[data-theme="dark"] .section__eyebrow { color: var(--gold-400); }
.section__title {
  font-family: var(--font-display);
  font-size: var(--text-3xl);
  font-weight: 900;
  color: var(--navy-950);
  margin-bottom: var(--space-4);
  line-height: 1.2;
  letter-spacing: -0.02em;
}
[data-theme="dark"] .section__title { color: var(--white); }
.section__subtitle {
  font-size: var(--text-lg);
  color: var(--text-secondary);
  line-height: 1.7;
}

/* ─── Cards ─── */
.card {
  background: var(--surface);
  border: 1px solid var(--border-light);
  border-radius: var(--radius-lg);
  padding: var(--space-8);
  transition: transform var(--transition), box-shadow var(--transition), border-color var(--transition);
  position: relative;
  overflow: hidden;
}
.card::before {
  content: "";
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 3px;
  background: linear-gradient(90deg, var(--gold-400), var(--gold-500));
  opacity: 0;
  transition: opacity var(--transition);
}
.card:hover {
  transform: translateY(-6px);
  box-shadow: var(--shadow-xl);
  border-color: var(--border-gold);
}
.card:hover::before { opacity: 1; }

.card__icon {
  width: 56px; height: 56px;
  border-radius: var(--radius);
  background: linear-gradient(135deg, rgba(197,160,40,0.12), rgba(197,160,40,0.04));
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: var(--space-5);
  transition: transform var(--transition-fast);
}
.card:hover .card__icon { transform: scale(1.1) rotate(-4deg); }

.card__icon svg {
  width: 26px; height: 26px;
  stroke: var(--gold-600);
  fill: none;
  stroke-width: 2;
  stroke-linecap: round;
  stroke-linejoin: round;
}

.card__title {
  font-family: var(--font-display);
  font-size: var(--text-xl);
  font-weight: 800;
  color: var(--navy-950);
  margin-bottom: var(--space-2);
}
[data-theme="dark"] .card__title { color: var(--white); }

.card__text {
  color: var(--text-secondary);
  font-size: var(--text-sm);
  line-height: 1.8;
}

/* ─── Grid layouts ─── */
.grid-3 {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: var(--space-6);
}
.grid-2 {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: var(--space-8);
}

/* ─── Services ─── */
.services-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
  gap: var(--space-6);
}

/* ─── Process ─── */
.process-section { background: var(--cream-100); }
[data-theme="dark"] .process-section { background: var(--surface-raised); }
.process-timeline {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: var(--space-6);
  position: relative;
}
.process-timeline::before {
  content: "";
  position: absolute;
  top: 28px;
  right: 12.5%;
  left: 12.5%;
  height: 2px;
  background: linear-gradient(90deg, transparent, var(--gold-400), transparent);
  opacity: 0.3;
}
.process-step {
  text-align: center;
  position: relative;
  z-index: 1;
}
.process-step__num {
  width: 56px; height: 56px;
  border-radius: 50%;
  background: linear-gradient(135deg, var(--gold-400), var(--gold-500));
  color: var(--navy-950);
  font-family: var(--font-display);
  font-size: var(--text-xl);
  font-weight: 900;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto var(--space-5);
  box-shadow: var(--shadow-gold);
  position: relative;
}
.process-step__num::after {
  content: "";
  position: absolute;
  inset: -6px;
  border-radius: 50%;
  border: 2px solid var(--gold-400);
  opacity: 0;
  transform: scale(0.8);
  transition: all var(--transition);
}
.process-step:hover .process-step__num::after {
  opacity: 0.3;
  transform: scale(1);
}
.process-step__title {
  font-family: var(--font-display);
  font-size: var(--text-lg);
  font-weight: 800;
  color: var(--navy-950);
  margin-bottom: var(--space-2);
}
[data-theme="dark"] .process-step__title { color: var(--white); }
.process-step__desc {
  font-size: var(--text-sm);
  color: var(--text-secondary);
  line-height: 1.7;
}

/* ─── Testimonials ─── */
.testimonials-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: var(--space-6);
}
.testimonial {
  background: var(--surface);
  border: 1px solid var(--border-light);
  border-radius: var(--radius-lg);
  padding: var(--space-8);
  position: relative;
  transition: transform var(--transition), box-shadow var(--transition);
}
.testimonial:hover {
  transform: translateY(-4px);
  box-shadow: var(--shadow-lg);
}
.testimonial::before {
  content: """;
  position: absolute;
  top: var(--space-6);
  right: var(--space-6);
  font-size: 4rem;
  color: var(--gold-500);
  opacity: 0.1;
  font-family: Georgia, serif;
  line-height: 1;
  pointer-events: none;
}
.testimonial__stars {
  color: var(--gold-400);
  font-size: var(--text-sm);
  letter-spacing: 0.15em;
  margin-bottom: var(--space-4);
}
.testimonial__text {
  font-size: var(--text-base);
  color: var(--text-primary);
  line-height: 1.9;
  margin-bottom: var(--space-6);
  font-style: italic;
}
.testimonial__author {
  display: flex;
  align-items: center;
  gap: var(--space-3);
}
.testimonial__avatar {
  width: 44px; height: 44px;
  border-radius: 50%;
  background: linear-gradient(135deg, var(--navy-800), var(--navy-600));
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--white);
  font-weight: 800;
  font-size: var(--text-sm);
  flex-shrink: 0;
}
.testimonial__name {
  font-weight: 800;
  color: var(--navy-950);
  font-size: var(--text-sm);
}
[data-theme="dark"] .testimonial__name { color: var(--white); }
.testimonial__role {
  font-size: var(--text-xs);
  color: var(--text-muted);
}

/* ─── FAQ ─── */
.faq-section { background: var(--cream-100); }
[data-theme="dark"] .faq-section { background: var(--surface-raised); }
.faq-list {
  max-width: 760px;
  margin-inline: auto;
}
.faq-item {
  background: var(--surface);
  border: 1px solid var(--border-light);
  border-radius: var(--radius);
  margin-bottom: var(--space-3);
  overflow: hidden;
  transition: box-shadow var(--transition);
}
.faq-item:hover { box-shadow: var(--shadow); }
.faq-item summary {
  padding: var(--space-5) var(--space-6);
  font-weight: 800;
  cursor: pointer;
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: var(--space-4);
  list-style: none;
  color: var(--navy-950);
  font-size: var(--text-base);
}
[data-theme="dark"] .faq-item summary { color: var(--white); }
.faq-item summary::-webkit-details-marker { display: none; }
.faq-item summary::after {
  content: "+";
  font-size: 1.5rem;
  color: var(--gold-500);
  font-weight: 300;
  transition: transform var(--transition);
  flex-shrink: 0;
}
.faq-item[open] summary::after { transform: rotate(45deg); }
.faq-item__content {
  padding: 0 var(--space-6) var(--space-5);
  color: var(--text-secondary);
  font-size: var(--text-sm);
  line-height: 1.9;
}

/* ─── CTA Section ─── */
.cta-section {
  background: linear-gradient(135deg, var(--navy-900), var(--navy-700));
  color: var(--white);
  padding: var(--space-24) 0;
  position: relative;
  overflow: hidden;
  text-align: center;
}
.cta-section::before {
  content: "";
  position: absolute;
  inset: 0;
  background: radial-gradient(circle at 70% 50%, rgba(197,160,40,0.10), transparent 50%);
}
.cta-section .container { position: relative; z-index: 1; }
.cta-section h2 {
  font-family: var(--font-display);
  font-size: var(--text-4xl);
  font-weight: 900;
  margin-bottom: var(--space-4);
  line-height: 1.2;
}
.cta-section p {
  font-size: var(--text-lg);
  color: var(--cream-200);
  opacity: 0.9;
  margin-bottom: var(--space-10);
  max-width: 560px;
  margin-inline: auto;
}

/* ─── Footer ─── */
.footer {
  background: var(--navy-950);
  color: var(--cream-200);
  padding: var(--space-20) 0 var(--space-10);
}
.footer-grid {
  display: grid;
  grid-template-columns: 2fr 1fr 1fr 1fr;
  gap: var(--space-10);
  margin-bottom: var(--space-12);
}
.footer-brand p {
  font-size: var(--text-sm);
  color: var(--text-muted);
  margin-top: var(--space-3);
  max-width: 280px;
  line-height: 1.8;
}
.footer-title {
  font-size: var(--text-xs);
  font-weight: 800;
  color: var(--white);
  margin-bottom: var(--space-4);
  text-transform: uppercase;
  letter-spacing: 0.08em;
}
.footer-links a {
  display: block;
  color: var(--text-muted);
  font-size: var(--text-sm);
  padding: var(--space-1) 0;
  transition: color var(--transition-fast), transform var(--transition-fast);
}
.footer-links a:hover { color: var(--gold-400); transform: translateX(-4px); }
.footer-bottom {
  border-top: 1px solid rgba(255,255,255,0.06);
  padding-top: var(--space-6);
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: var(--space-4);
  font-size: var(--text-xs);
  color: var(--text-muted);
}

/* ─── Floating WhatsApp ─── */
.float-whatsapp {
  position: fixed;
  bottom: var(--space-6);
  left: var(--space-6);
  z-index: 100;
  width: 56px; height: 56px;
  border-radius: 50%;
  background: linear-gradient(135deg, #25d366, #128c7e);
  color: var(--white);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 1.5rem;
  box-shadow: 0 8px 24px rgba(37, 211, 102, 0.35);
  transition: transform var(--transition-fast), box-shadow var(--transition-fast);
}
.float-whatsapp:hover {
  transform: scale(1.12) rotate(-8deg);
  box-shadow: 0 12px 32px rgba(37, 211, 102, 0.45);
}

/* ─── Scroll Animations ─── */
.reveal {
  opacity: 0;
  transform: translateY(40px);
  transition: opacity 0.8s var(--ease-out-expo), transform 0.8s var(--ease-out-expo);
}
.reveal.is-visible {
  opacity: 1;
  transform: translateY(0);
}
.reveal-delay-1 { transition-delay: 0.1s; }
.reveal-delay-2 { transition-delay: 0.2s; }
.reveal-delay-3 { transition-delay: 0.3s; }
.reveal-delay-4 { transition-delay: 0.4s; }

/* ─── Responsive ─── */
@media (max-width: 1024px) {
  .grid-3 { grid-template-columns: repeat(2, 1fr); }
  .footer-grid { grid-template-columns: 1fr 1fr; }
  .stats-grid { grid-template-columns: repeat(2, 1fr); }
  .process-timeline { grid-template-columns: repeat(2, 1fr); }
  .process-timeline::before { display: none; }
}

@media (max-width: 768px) {
  .grid-3, .grid-2, .testimonials-grid { grid-template-columns: 1fr; }
  .stats-grid { grid-template-columns: repeat(2, 1fr); gap: var(--space-6); }
  .footer-grid { grid-template-columns: 1fr; gap: var(--space-8); }
  .main-nav {
    display: none;
    position: absolute;
    top: 100%;
    left: 0;
    right: 0;
    background: var(--cream-50);
    border-bottom: 1px solid var(--border-light);
    padding: var(--space-4);
    box-shadow: var(--shadow-lg);
  }
  [data-theme="dark"] .main-nav { background: var(--surface); }
  .main-nav.is-open { display: block; }
  .main-nav.is-open ul { flex-direction: column; gap: var(--space-3); align-items: flex-start; }
  .nav-toggle { display: flex; }
  .hero__title { font-size: var(--text-4xl); }
  .section { padding: var(--space-16) 0; }
  .process-timeline { grid-template-columns: 1fr; }
  .stat-item:not(:last-child)::after { display: none; }
}

@media (max-width: 480px) {
  .hero__actions { flex-direction: column; }
  .hero__actions .btn { width: 100%; }
  .stats-grid { grid-template-columns: 1fr; }
  .hero { min-height: auto; padding: var(--space-16) 0; }
}

/* ─── Insights / Articles ─── */
.insights-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: var(--space-6);
}
.insight-card {
  background: var(--surface);
  border: 1px solid var(--border-light);
  border-radius: var(--radius-lg);
  overflow: hidden;
  transition: transform var(--transition), box-shadow var(--transition);
}
.insight-card:hover {
  transform: translateY(-6px);
  box-shadow: var(--shadow-xl);
}
.insight-card__cover {
  height: 180px;
  background: linear-gradient(135deg, var(--navy-800), var(--navy-600));
  display: flex;
  align-items: center;
  justify-content: center;
}
.insight-card__body { padding: var(--space-6); }
.insight-card__tag {
  font-size: var(--text-xs);
  color: var(--gold-600);
  font-weight: 700;
  margin-bottom: var(--space-2);
}
.insight-card__title {
  font-family: var(--font-display);
  font-size: var(--text-lg);
  font-weight: 800;
  color: var(--navy-950);
  margin-bottom: var(--space-2);
  line-height: 1.4;
}

/* ─── Team ─── */
.team-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: var(--space-6);
}
.team-card {
  background: var(--surface);
  border: 1px solid var(--border-light);
  border-radius: var(--radius-lg);
  overflow: hidden;
  transition: transform var(--transition), box-shadow var(--transition);
}
.team-card:hover {
  transform: translateY(-6px);
  box-shadow: var(--shadow-xl);
}
.team-card__photo {
  height: 240px;
  background: linear-gradient(135deg, var(--navy-800), var(--navy-600));
  display: flex;
  align-items: center;
  justify-content: center;
}
.team-card__avatar {
  width: 100px; height: 100px;
  border-radius: 50%;
  background: linear-gradient(135deg, var(--gold-400), var(--gold-500));
  display: flex;
  align-items: center;
  justify-content: center;
  font-family: var(--font-display);
  font-size: 2.5rem;
  font-weight: 900;
  color: var(--navy-950);
}
.team-card__body { padding: var(--space-6); }
.team-card__name {
  font-family: var(--font-display);
  font-size: var(--text-lg);
  font-weight: 800;
  color: var(--navy-950);
  margin-bottom: var(--space-1);
}
.team-card__role {
  font-size: var(--text-xs);
  color: var(--gold-600);
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.05em;
  margin-bottom: var(--space-3);
}

/* ─── Form Elements ─── */
.form-control {
  width: 100%;
  padding: var(--space-3) var(--space-4);
  border-radius: var(--radius);
  border: 1px solid var(--border-medium);
  background: var(--cream-50);
  font-family: inherit;
  font-size: var(--text-sm);
  outline: none;
  transition: border-color var(--transition-fast), box-shadow var(--transition-fast);
}
.form-control:focus {
  border-color: var(--gold-400);
  box-shadow: 0 0 0 3px rgba(197,160,40,0.15);
}
select.form-control { cursor: pointer; }

/* ─── Utilities ─── */
.hidden-mobile { display: inline-flex; }
@media (max-width: 768px) { .hidden-mobile { display: none !important; } }

/* ─── Reduced Motion ─── */
@media (prefers-reduced-motion: reduce) {
  *, *::before, *::after {
    animation-duration: 0.01ms !important;
    animation-iteration-count: 1 !important;
    transition-duration: 0.01ms !important;
  }
  .reveal { opacity: 1; transform: none; }
}
